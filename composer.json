            "Calevans\\AnswerEngineOptimization\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.4",
        "eicc/utils": "^1.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "extra": {
        "staticforge": {
            "feature": "Calevans\\AnswerEngineOptimization\\Feature"
        }
    }
}